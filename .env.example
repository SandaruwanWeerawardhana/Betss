DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=1234
DB_NAME=scraper_db

HORSE_API_1_URL=https://racingapi.betss.com/api/Race/GetFeaturedRaces/HR/next15?isTestUser=false
HORSE_API_2_URL=https://racingapi.betss.com/api/Race/GetFeaturedRaces/HR/today?isTestUser=false
HORSE_API_3_URL=https://racingapi.betss.com/api/Race/GetFeaturedRaces/HR/tomorrow?isTestUser=false
HORSE_API_4_URL=https://racingapi.betss.com/api/Race/GetFeaturedRaces/HR/future?isTestUser=false


HARNESS_API_1_URL=https://racingapi.betss.com/api/Race/GetFeaturedRaces/HA/tomorrow?isTestUser=false
HARNESS_API_2_URL=https://racingapi.betss.com/api/Race/GetFeaturedRaces/HA/today?isTestUser=false
HARNESS_API_3_URL=https://racingapi.betss.com/api/Race/GetFeaturedRaces/HA/future?isTestUser=false

GRAYHOUND_API_1_URL=https://racingapi.betss.com/api/Race/GetFeaturedRaces/DG/today?isTestUser=false
GRAYHOUND_API_2_URL=https://racingapi.betss.com/api/Race/GetFeaturedRaces/DG/tomorrow?isTestUser=false
GRAYHOUND_API_3_URL=https://racingapi.betss.com/api/Race/GetFeaturedRaces/DG/future?isTestUser=false

# Virtual Horse (HR) races
VHORSE_API_1_URL=https://racingapi.betss.com/api/Race/GetFeaturedVirtualRaces/HR/today
VHORSE_API_2_URL=https://racingapi.betss.com/api/Race/GetFeaturedVirtualRaces/HR/tomorrow

# Virtual Greyhound (DG) races
VGREYHOUND_API_1_URL=https://racingapi.betss.com/api/Race/GetFeaturedVirtualRaces/DG/today

# Per-race detail endpoints (time-gated; only called after race start_time + delay)
FETCH_RACE_DETAILS=1

# Stores meeting + races + results from that response.
FETCH_TODAY_MEETING_DATA_BY_ID=0

# If 1, calls Race/GetRaceDetailsById/{raceId} for each race id read from the `races` table.
FETCH_RACE_DETAILS_BY_ID=0
MAX_RACE_IDS_PER_CYCLE=50

# If 1, reads ALL ids from the `races` table and calls per-race APIs one-by-one.
# Default is 0 to avoid heavy load.
FETCH_ALL_RACE_IDS=0

# Batch size used only when FETCH_ALL_RACE_IDS=1
RACE_ID_BATCH_SIZE=500

RACE_RUNNERS_BY_RACE_URL_TEMPLATE=https://racingapi.betss.com/api/racerunner/GetRaceRunnersByRace/{raceId}
TODAY_MEETING_DATA_BY_ID_URL_TEMPLATE=https://racingapi.betss.com/api/meeting/GetTodayMeetingDataById/{raceId}
RACE_DETAILS_BY_ID_URL_TEMPLATE=https://racingapi.betss.com/api/Race/GetRaceDetailsById/{raceId}

# Time-gated per-race settings
# Delay after scheduled start_time before per-race detail calls run
RESULT_FETCH_DELAY_MINUTES=15
# How often to scan DB for races that are due
RESULT_CHECK_INTERVAL_SECONDS=30
# Max races evaluated per scan
RESULT_CANDIDATE_MAX_ROWS=500

# If you changed your schema earlier and want a clean rebuild (DATA LOSS):
# RECREATE_SCHEMA=1


HORSE_API_1_INTERVAL=300
HORSE_API_2_INTERVAL=300
HORSE_API_3_INTERVAL=300
HORSE_API_4_INTERVAL=300


HARNESS_API_1_INTERVAL=300
HARNESS_API_2_INTERVAL=300
HARNESS_API_3_INTERVAL=300

GRAYHOUND_API_1_INTERVAL=300
GRAYHOUND_API_2_INTERVAL=300
GRAYHOUND_API_3_INTERVAL=300

VHORSE_API_1_INTERVAL=300
VHORSE_API_2_INTERVAL=300

VGREYHOUND_API_1_INTERVAL=300


POLL_INTERVAL=300
